# GreaterWMS Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Django Core
DJANGO_SECRET_KEY=change-me-to-a-random-50-character-string-using-openssl-rand-hex-32
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database Configuration
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3
# For PostgreSQL:
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=greaterwms
# DATABASE_USER=greaterwms_user
# DATABASE_PASSWORD=your-secure-password
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# CORS Configuration
CORS_ALLOW_ALL=False
CORS_ORIGIN_WHITELIST=https://yourdomain.com,https://www.yourdomain.com

# CSRF
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Security
JWT_SALT=change-me-to-a-random-string-using-openssl-rand-hex-32

# Static/Media Files
STATIC_URL=/static/
MEDIA_URL=/media/
